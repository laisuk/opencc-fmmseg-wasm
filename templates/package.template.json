{
  "name": "@laisuk/opencc-fmmseg-wasm",
  "type": "module",
  "description": "WebAssembly bindings for opencc-fmmseg, a high-performance OpenCC-compatible Simplified/Traditional Chinese converter.",
  "version": "0.2.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laisuk/opencc-fmmseg-wasm.git"
  },
  "bin": {
    "opencc-fmmseg": "bin/opencc.js"
  },
  "files": [
    "bin/",
    "opencc_fmmseg_wasm_bg.wasm",
    "opencc_fmmseg_wasm.js",
    "opencc_fmmseg_wasm.d.ts"
  ],
  "main": "opencc_fmmseg_wasm.js",
  "types": "opencc_fmmseg_wasm.d.ts",
  "sideEffects": [
    "./snippets/*"
  ],
  "keywords": [
    "opencc",
    "chinese",
    "simplified-chinese",
    "traditional-chinese",
    "wasm",
